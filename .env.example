# Yes Energy API Credentials
YES_ENERGY_USERNAME=
YES_ENERGY_PASSWORD=

# Enverus API Credentials
USERNAME=
PASSWORD=

# AG2 API Credentials
USER=
PASSWORD=
Profile=

# Smartbidder API Credentials
APPLICATION_ID=
CLIENT_ID=
CLIENT_SECRET=
_TENANT=onascend.com
